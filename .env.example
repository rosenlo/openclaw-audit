# Optional overrides for local OpenClaw layouts

OPENCLAW_HOME=~/.openclaw
OPENCLAW_LOG_DIR=/tmp/openclaw
# OPENCLAW_GATEWAY_LOG=~/Library/Logs/openclaw/gateway.log
LITELLM_DIR=~/litellm
# OPENCLAW_AUDIT_TZ=+07:00
# When unset, the audit auto-detects the system local timezone
# (via datetime.now().astimezone()). Set explicitly to override:
#   +HH:MM, -HH:MM, +HHMM, +HH, or UTC (half-hour offsets like +05:30 OK).
OPENCLAW_NODE=node
OPENCLAW_CLI=openclaw

# LiteLLM log format: set JSON_LOGS=true on the LiteLLM process so err.log
# lines carry a full ISO timestamp (date+year). This tool only parses JSON
# lines; legacy HH:MM:SS text lines are skipped. Use JSON_LOGS, not
# LITELLM_LOG=JSON (the latter is parsed as a log level and raises).
# JSON_LOGS=true

# LiteLLM log rotation (copytruncate at startup when file exceeds this size):
# LITELLM_LOG_MAX_SIZE_BYTES=52428800   # 50 MB
# LITELLM_LOG_KEEP=5
